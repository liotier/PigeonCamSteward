[Unit]
Description=nestcam-streamer: hourly archive retention pass (FR11)
Documentation=file:///opt/PigeonCamSteward/SPEC.md

[Service]
Type=oneshot
User=root
Environment=NESTCAM_CONFIG=/etc/nestcam/config.yaml
ExecStart=/opt/PigeonCamSteward/bin/nestcam-archive-trim.sh
SyslogIdentifier=nestcam-archive-trim
TimeoutStartSec=300
