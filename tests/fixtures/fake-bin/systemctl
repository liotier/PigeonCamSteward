#!/usr/bin/env bash
# Fake systemctl for tests. Records each invocation, with a high-resolution
# timestamp, to $FAKE_SYSTEMCTL_LOG instead of actually managing services -
# this sandbox has no running init (systemd is not PID 1), and even where
# it is, tests should not depend on real unit activation. Lets tests assert
# call sequence/verbs and timing (e.g. FR14's stop->gap->start).
: "${FAKE_SYSTEMCTL_LOG:?FAKE_SYSTEMCTL_LOG must be set for the fake systemctl}"
printf '%s %s\n' "$(date +%s.%N)" "$*" >> "$FAKE_SYSTEMCTL_LOG"

if [[ "$1" == "is-active" ]]; then
    # FAKE_SYSTEMCTL_ACTIVE controls the simulated unit state for tests
    # exercising watchdog's is-active gate - defaults to "active" so every
    # test predating this flag keeps seeing the unit as up. Real systemctl
    # prints the state word to stdout unless --quiet is given (which
    # bin/pigeoncam-watchdog.sh's is-active gate always passes, so this
    # stays silent for it exactly as before); bin/pigeoncam-ctl.sh's status
    # subcommand calls it without --quiet specifically to capture that word.
    state="${FAKE_SYSTEMCTL_ACTIVE:-active}"
    quiet=false
    for arg in "$@"; do
        [[ "$arg" == "--quiet" ]] && quiet=true
    done
    if [[ "$quiet" == "false" ]]; then
        printf '%s\n' "$state"
    fi
    [[ "$state" == "active" ]]
    exit $?
fi

if [[ "$1" == "is-enabled" ]]; then
    # FAKE_SYSTEMCTL_ENABLED_STATE controls the simulated state for every
    # unit doctor.sh's check_units_enabled checks in a run - every doctor
    # test scenario checks "all units in the same state" (a fresh install
    # has none installed yet; a configured system has all of them
    # enabled), so one blanket value is enough, no per-unit table needed.
    # Defaults to "enabled" so tests predating this flag keep seeing every
    # unit as enabled.
    state="${FAKE_SYSTEMCTL_ENABLED_STATE:-enabled}"
    printf '%s\n' "$state"
    [[ "$state" == "enabled" || "$state" == "static" ]]
    exit $?
fi

# FAKE_SYSTEMCTL_FAIL_UNIT: makes the fallthrough action verbs (start/stop/
# restart/enable/disable) fail for one named unit, so tests can exercise
# "keep going past one failure and aggregate" logic (pigeoncam-ctl.sh's
# apply()) without touching the is-active/is-enabled branches above. Unset
# by default, so every test predating this flag is unaffected.
if [[ -n "${FAKE_SYSTEMCTL_FAIL_UNIT:-}" ]]; then
    for arg in "$@"; do
        [[ "$arg" == "$FAKE_SYSTEMCTL_FAIL_UNIT" ]] && exit 1
    done
fi

exit 0
