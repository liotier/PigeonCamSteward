#!/usr/bin/env bash
# Fake ffmpeg for tests. Two independent, unrelated modes:
#
#   -version - pigeoncam-doctor.sh's build-flag detection, without depending
#              on the real ffmpeg's exact build. Controlled via
#              FAKE_FFMPEG_MODE:
#                good     - reports libx264 + gnutls present (RTMPS ok)
#                no_rtmps - reports libx264 present but no gnutls/openssl
#              Only implements -version; anything unrecognized fails loudly
#              so a test can't accidentally let this fake stand in for a
#              real encode.
#
#   anything else, with FAKE_FFMPEG_ARGV_LOG set - pigeoncam-stream.sh's
#              real invocation shape (it execs ffmpeg as its last step).
#              Logs the full argv and exits 0 immediately - never attempts
#              an actual encode/stream - so a test can inspect exactly what
#              pigeoncam-stream.sh built without a real ffmpeg or camera.
if [[ "$1" == "-version" ]]; then
    case "${FAKE_FFMPEG_MODE:-good}" in
        good)
            echo "ffmpeg version 6.1.1-fake Copyright (c) 2000-2023 the FFmpeg developers"
            echo "configuration: --prefix=/usr --enable-gpl --enable-libx264 --enable-gnutls --enable-libmp3lame"
            ;;
        no_rtmps)
            echo "ffmpeg version 6.1.1-fake Copyright (c) 2000-2023 the FFmpeg developers"
            echo "configuration: --prefix=/usr --enable-gpl --enable-libx264 --enable-libmp3lame"
            ;;
        *)
            echo "fake-ffmpeg: unknown FAKE_FFMPEG_MODE=$FAKE_FFMPEG_MODE" >&2
            exit 1
            ;;
    esac
    exit 0
fi
if [[ -n "${FAKE_FFMPEG_ARGV_LOG:-}" ]]; then
    printf '%s\n' "$*" >> "$FAKE_FFMPEG_ARGV_LOG"
    exit 0
fi
echo "fake-ffmpeg: only -version is implemented, or set FAKE_FFMPEG_ARGV_LOG to capture other invocations (got: $*)" >&2
exit 1
